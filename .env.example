# API Keys para o sistema de memória
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Diretório do banco de memória (default: ~/.espelho)
MEMORIA_DIR=~/.config/espelho

# Dados pessoais do usuário
MIRROR_USER_NAME=Seu Nome
# Diretório dos dados pessoais (absoluto ou relativo ao repo)
# Exemplos: users/me (relativo ao repo), ~/.config/espelho/seu-nome (absoluto)
MIRROR_USER_DIR=users/me
